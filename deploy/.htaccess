# Ionos Apache Configuration for Bio Green Wax
# This file should be placed in the web root directory

RewriteEngine On
RewriteBase /

# If the request is for the API, route to api/index.php
RewriteCond %{REQUEST_URI} ^/api/(.*)$
RewriteRule ^api/(.*)$ api/index.php [QSA,L]

# Route sitemap.xml and robots.txt to the PHP API for dynamic generation
RewriteRule ^sitemap\.xml$ api/index.php [QSA,L]
RewriteRule ^robots\.txt$ api/index.php [QSA,L]
RewriteRule ^robot\.txt$ api/index.php [QSA,L]

# Bot/AI crawler pre-rendering - serve full HTML to AI bots
RewriteCond %{HTTP_USER_AGENT} (Googlebot|Google-Extended|Google-InspectionTool|Storebot-Google|GoogleOther|Bingbot|BingPreview|msnbot|Slurp|DuckDuckBot|Baiduspider|YandexBot|GPTBot|ChatGPT-User|OAI-SearchBot|ClaudeBot|Claude-Web|anthropic-ai|PerplexityBot|YouBot|CCBot|cohere-ai|CohereBot|Google-Gemini|Bytespider|Amazonbot|Applebot|Applebot-Extended|facebookexternalhit|FacebookBot|Twitterbot|LinkedInBot|WhatsApp|TelegramBot|Meta-ExternalAgent|Meta-ExternalFetcher|SemrushBot|AhrefsBot|MJ12bot|DotBot|Diffbot|PetalBot|SeznamBot|DataForSeoBot|ImagesiftBot|Seekr|AI2Bot) [NC]
RewriteCond %{REQUEST_URI} !^/api/
RewriteCond %{REQUEST_URI} !^/assets/
RewriteCond %{REQUEST_URI} !^/images/
RewriteCond %{REQUEST_URI} !^/uploads/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^(.*)$ api/bot-renderer.php [QSA,L]

# If the request is for an existing file, serve it
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# If the request is for an existing directory, serve it
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Otherwise, route to index.html (React SPA routing)
RewriteRule ^ index.html [L]

# Enable GZIP compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json
</IfModule>

# Set proper MIME types
<IfModule mod_mime.c>
    AddType application/javascript .js
    AddType text/css .css
    AddType application/json .json
</IfModule>

# Cache static assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
</IfModule>
