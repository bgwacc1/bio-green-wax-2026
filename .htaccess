# Ionos Apache Configuration for Bio Green Wax
# This file should be placed in the web root directory

RewriteEngine On
RewriteBase /

# If the request is for the API, route to api/index.php
RewriteCond %{REQUEST_URI} ^/api/(.*)$
RewriteRule ^api/(.*)$ api/index.php [QSA,L]

# Bot/AI crawler pre-rendering - serve full HTML to AI bots
RewriteCond %{HTTP_USER_AGENT} (GPTBot|ChatGPT-User|Google-Extended|CCBot|anthropic-ai|ClaudeBot|Claude-Web|Bytespider|Amazonbot|PerplexityBot|YouBot|Applebot-Extended|cohere-ai|FacebookBot|Meta-ExternalAgent|Diffbot|ImagesiftBot|Seekr) [NC]
RewriteCond %{REQUEST_URI} !^/api/
RewriteCond %{REQUEST_URI} !^/assets/
RewriteCond %{REQUEST_URI} !^/images/
RewriteCond %{REQUEST_URI} !^/uploads/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^(.*)$ api/bot-renderer.php [QSA,L]

# If the request is for an existing file, serve it
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# If the request is for an existing directory, serve it
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Otherwise, route to index.html (React SPA routing)
RewriteRule ^ index.html [L]

# Enable GZIP compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json
</IfModule>

# Set proper MIME types
<IfModule mod_mime.c>
    AddType application/javascript .js
    AddType text/css .css
    AddType application/json .json
</IfModule>

# Cache static assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
</IfModule>
